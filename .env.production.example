# Core
NODE_ENV=production
TZ=Asia/Tokyo

# Domain used in Nginx certificate path (frontend/nginx/default.conf)
APP_DOMAIN=example.com

# Database
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=chatbot

# Backend security
SESSION_SECRET=change_this_session_secret
CSRF_SECRET=change_this_csrf_secret
PASSWORD_PEPPER=change_this_password_pepper

# Public URL
FRONTEND_URL=https://example.com

# Email (optional)
SENDGRID_USERNAME=
SENDGRID_PASSWORD=

# LLM
OPENAI_API_KEY=

# Internal service URLs (recommended for production)
DB_HOST=db
DB_PORT=5432
BACKEND_PORT=3000
LLM_URL=http://llm:8000

MASTER_ADMIN_EMPLOYEE_NO=999999
MASTER_ADMIN_NAME=システム管理者
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_ROLE=admin
MASTER_ADMIN_PASSWORD=your_password
MASTER_ADMIN_dep1_code=AAAAAA
MASTER_ADMIN_dep1_name=マスター
MASTER_ADMIN_dep2_code=BBBBBB
MASTER_ADMIN_dep2_name=マスター
MASTER_ADMIN_dep3_code=CCCCCC
MASTER_ADMIN_dep3_name=マスター

MASTER_USER_EMPLOYEE_NO=000000
MASTER_USER_NAME=システムユーザー
MASTER_USER_EMAIL=user@example.com
MASTER_USER_ROLE=user
MASTER_USER_PASSWORD=your_password
MASTER_USER_dep1_code=AAAAAA
MASTER_USER_dep1_name=マスター
MASTER_USER_dep2_code=BBBBBB
MASTER_USER_dep2_name=マスター
MASTER_USER_dep3_code=CCCCCC
MASTER_USER_dep3_name=マスター
